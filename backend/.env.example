# For host-based development (running `npm run dev` directly on your machine):
DATABASE_URL=postgresql://quantum:password@localhost:5432/quantum_project
# When running inside Docker Compose, DATABASE_URL is automatically overridden
# in docker-compose.yml to use the postgres service hostname (postgres:5432).
JWT_SECRET=your-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_ALLOW_PAID=false
REDIS_URL=redis://:redispass@localhost:6379
APP_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx
VAPID_EMAIL=mailto:admin@quantumproject.app
