# Quantum Project — Production Environment Variables
# Copy to .env.production and fill in real values

# Domain
DOMAIN=quantumproject.app
ACME_EMAIL=admin@quantumproject.app

# Database
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET

# AI (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_ALLOW_PAID=false

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_EMAIL=mailto:admin@quantumproject.app
